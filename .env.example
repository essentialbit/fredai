# FredAI — Environment Configuration Template
# Copy this to .env and fill in your values:
#   cp .env.example .env

# ── X / TWITTER API ──────────────────────────────────────────────────────────
# Get credentials at: https://developer.twitter.com
X_BEARER_TOKEN=your_x_bearer_token_here
X_CONSUMER_KEY=your_consumer_key_here
X_CONSUMER_SECRET=your_consumer_secret_here
X_ACCESS_TOKEN=your_access_token_here
X_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# ── AI PROVIDER ───────────────────────────────────────────────────────────────
# NOTE: Claude Pro (claude.ai) subscriptions are web-UI only — cannot be used
# by third-party apps. Use the API key below OR free local Ollama.
#
# Option A — Anthropic API (pay-per-token, ~$0.25/1M tokens on Haiku):
ANTHROPIC_API_KEY=your_anthropic_api_key_here
#
# Option B — Ollama free local inference (no API cost, fully on-device):
#   Install: https://ollama.com  then: ollama pull llama3.2
#   Set: AI_PROVIDER=ollama
#
# Option C — Auto (Anthropic if key set, else Ollama, else degraded)
AI_PROVIDER=auto

OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── NASDAQ DATA LINK (optional — free tier works without key) ─────────────────
NASDAQ_API_KEY=

# ── PRIVACY ──────────────────────────────────────────────────────────────────
PRIVACY_MODE=true
STRIP_PORTFOLIO_FROM_AI=true
DATA_RETENTION_DAYS=90

# ── APP ───────────────────────────────────────────────────────────────────────
# Generate a strong random key: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_to_a_random_64char_hex_string
PORT=8080

# ── SECURITY ──────────────────────────────────────────────────────────────────
# Initial admin password — only used when the DB is first created (no users exist).
# After first run, change via the UI or remove this line (it has no effect once admin exists).
# If unset, a random password is generated and printed to the console ONCE.
FREDAI_ADMIN_PASSWORD=

# Deploy secret — required for CI webhook to push updates to this instance.
# Must match FREDAI_DEPLOY_SECRET in your GitHub repository's Actions Secrets.
# If unset, CI-push updates are disabled (updates still work via 6h poll or manual UI).
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
FREDAI_DEPLOY_SECRET=

# ── AUTO-UPDATE ───────────────────────────────────────────────────────────────
# notify = show badge when update available (default)
# auto   = pull and apply updates silently every 6h
# off    = never check for updates
AUTO_UPDATE=notify

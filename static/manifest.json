{
  "id": "com.essentialbit.fredai",
  "name": "FredAI Financial Intelligence",
  "short_name": "FredAI",
  "description": "AI-powered financial signals, portfolio tracking, and Fred's market intelligence.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "browser"],
  "orientation": "any",
  "background_color": "#03080f",
  "theme_color": "#03080f",
  "lang": "en",
  "categories": ["finance", "business"],
  "icons": [
    { "src": "/static/icons/icon-16.png",  "sizes": "16x16",   "type": "image/png" },
    { "src": "/static/icons/icon-32.png",  "sizes": "32x32",   "type": "image/png" },
    { "src": "/static/icons/icon-48.png",  "sizes": "48x48",   "type": "image/png" },
    { "src": "/static/icons/icon-128.png", "sizes": "128x128", "type": "image/png" },
    { "src": "/static/icons/icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any maskable" },
    { "src": "/static/icons/icon-256.png", "sizes": "256x256", "type": "image/png" },
    { "src": "/static/icons/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any maskable" },
    { "src": "/static/icons/icon-1024.png","sizes": "1024x1024","type": "image/png" }
  ],
  "screenshots": [
    {
      "src": "/static/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "form_factor": "wide",
      "label": "FredAI Dashboard"
    }
  ],
  "shortcuts": [
    {
      "name": "Portfolio",
      "short_name": "Portfolio",
      "description": "View your portfolio P&L",
      "url": "/?tab=portfolio",
      "icons": [{ "src": "/static/icons/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Trending",
      "short_name": "Trending",
      "description": "Top trending assets from X signals",
      "url": "/?tab=trending",
      "icons": [{ "src": "/static/icons/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "AI Universe",
      "short_name": "AI",
      "description": "AI sector watchlist",
      "url": "/?tab=ai",
      "icons": [{ "src": "/static/icons/icon-192.png", "sizes": "192x192" }]
    }
  ],
  "prefer_related_applications": false,
  "launch_handler": {
    "client_mode": "focus-existing"
  }
}
